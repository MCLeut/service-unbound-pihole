{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from", "git+https://github.com/oraios/serena@v1.5.3",
        "serena", "start-mcp-server",
        "--context", "claude-code",
        "--project-from-cwd",
        "--enable-web-dashboard", "false",
        "--enable-gui-log-window", "false"
      ]
    }
  }
}
